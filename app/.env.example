# ── Vectis environment ────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real keys.

# Chain: 84532 = Base Sepolia (real on-chain redemption, direct via DelegationManager)
#        8453  = Base mainnet (gasless via the 1Shot relayer)
ACTIVE_CHAIN_ID=84532

# Server-side signer for the User smart account (the agent hierarchy derives
# Governor/Researcher/Summarizer keys from this via keccak salts). Use a TESTNET key.
WALLET_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Venice AI (OpenAI-compatible). Needs credits for live reasoning; without them
# the app falls back to deterministic templates and says so.
VENICE_API_KEY=

# RPC endpoints (public fallbacks used if omitted)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# 1Shot relayer (only used on mainnet / chainId 8453)
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
ONESHOT_API_KEY=
ONESHOT_WEBHOOK_SECRET=

# Optional: x402 payment receiver for the data endpoint
# X402_PAY_TO=0x...
